{
  "name": "tapuia",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "description": "Tapuia — Tycoon de mineração + indústria + governo em Santa Catarina.",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "lint:fix": "eslint --fix src tests",
    "format": "prettier --write \"src/**/*.{js,ts,json,css,html}\" \"tests/**/*.{js,ts}\" \"*.{html,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,ts,json,css,html}\" \"tests/**/*.{js,ts}\""
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/ui": "^2.1.0",
    "eslint": "^9.15.0",
    "globals": "^15.12.0",
    "happy-dom": "^15.11.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
